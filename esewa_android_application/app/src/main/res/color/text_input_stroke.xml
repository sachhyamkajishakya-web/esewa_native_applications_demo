<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Error -->
    <item android:color="@color/primary" android:state_focused="false" android:state_enabled="true" />

    <!-- Focused -->
    <item android:color="@color/textColor" android:state_focused="true" />

    <!-- Disabled -->
    <item android:color="#80FFFFFF" android:state_enabled="false" />

    <!-- Default (unfocused) -->
    <item android:color="@color/textColor" />

</selector>